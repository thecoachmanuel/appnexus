# ============================================
# AppNexus v1.0.0 - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ============================================
# Supabase Configuration (Required)
# ============================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable/anon key (safe for frontend)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Supabase project ID
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_project_id

# ============================================
# Supabase Backend Secrets (Edge Functions)
# ============================================
# These are configured via Supabase Dashboard > Settings > Secrets
# or via Lovable Cloud interface

# Supabase service role key (server-side only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase database URL (for direct database access)
# SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================
# AI Services (Optional)
# ============================================
# Lovable AI Gateway API Key (for AI-powered features)
# LOVABLE_API_KEY=your_lovable_api_key

# ElevenLabs API Key (for text-to-speech features)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ============================================
# Self-Hosting Configuration (Optional)
# ============================================
# Email address for automatic admin role assignment on signup
# INITIAL_ADMIN_EMAIL=admin@example.com

# Secret key for securing the setup wizard endpoint
# SETUP_SECRET_KEY=your_secure_random_string

# ============================================
# Appetize.io Integration (Optional)
# ============================================
# Configured via Admin Dashboard > Integrations
# APPETIZE_API_KEY=your_appetize_api_key

# ============================================
# Build Server Configuration (Optional)
# ============================================
# For self-hosted build servers
# BUILD_SERVER_URL=http://localhost:3001
# BUILD_SERVER_API_KEY=your_build_server_key

# ============================================
# Application Settings
# ============================================
# Application environment (development, staging, production)
NODE_ENV=development

# Application port (for local development)
PORT=8080

# ============================================
# Demo / Test Mode (Optional)
# ============================================
# Enable or disable demo mode globally via environment.
# When set, this OVERRIDES the database demo_mode setting.
# Values: true | false | (leave empty to defer to database setting)
# Demo accounts: admin@demo.com, user@demo.com
# Effects: Shows demo banner, enables guided tour, bypasses credit checks for demo accounts
# NEXT_PUBLIC_DEMO_MODE=true

# ============================================
# Payment Gateways (Required for Checkout)
# ============================================
# PayPal
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_ENVIRONMENT=sandbox # use 'live' for production

# Coinbase Commerce
# COINBASE_COMMERCE_API_KEY=your_coinbase_api_key
# COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret
